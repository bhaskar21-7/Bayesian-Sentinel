# Copy this file to .env (or export these directly) before running main.py
# with live LLM narrative generation. Never commit a real .env file.

# Required for live LLM calls (Threat Summary / Root Cause / Executive
# Summary narrative sections). Get a free key at https://aistudio.google.com/apikey
# (sign in with any Google account, no credit card, no billing setup).
# Free tier (gemini-2.5-flash): ~10 req/min, 250 req/day — plenty for a
# demo, since Module 4 only calls the LLM on events that clear the risk>70
# gate. Without this set, the pipeline falls back to SOC_LLM_MOCK_MODE
# automatically only if you also pass --mock-llm or set SOC_LLM_MOCK_MODE=1
# below — otherwise it raises a clear error rather than silently proceeding.
GEMINI_API_KEY=AIza...

# Set to 1 to force mock LLM mode (no API key needed, no API cost) — useful
# for local development, CI, and demoing the orchestration pipeline without
# live credentials. Mock output is always clearly labeled as such.
SOC_LLM_MOCK_MODE=0
